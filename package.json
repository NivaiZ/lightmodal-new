{
  "name": "lightmodal",
  "version": "4.3.0",
  "description": "Zero-dependency vanilla JS modal library",
  "type": "module",
  "scripts": {
    "dev": "node scripts/html-refs.js dev && vite",
    "build": "npm run build:js && npm run build:css && node scripts/html-refs.js min",
    "build:js": "esbuild lightmodal.js --bundle=false --minify --legal-comments=none --outfile=lightmodal.min.js",
    "build:css": "esbuild lightmodal.css --bundle=false --minify --outfile=lightmodal.min.css"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "vite": "^8.0.10"
  },
  "keywords": [
    "modal",
    "lightbox",
    "vanilla-js",
    "zero-dependency"
  ],
  "license": "MIT"
}
